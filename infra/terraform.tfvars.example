# Copy this file to terraform.tfvars and fill in the values
# DO NOT commit terraform.tfvars to source control

subscription_id     = "<your-subscription-id>"
tenant_id           = "<your-tenant-id>"
resource_group_name = "rg-osa-poc"

# Sensitive variables - replace with actual values
iot_hub_connection_string                       = "<your-iot-hub-connection-string>"
iot_hub_container_name                          = "<your-iot-hub-container-name>"
vulnerability_assessment_storage_container_path = "https://<storage-account>.blob.core.windows.net/<container>/"
sql_admin_password                              = "<your-strong-sql-password>"

# Optional overrides (defaults match ARM template)
# sql_admin_login              = "sqladmin"
# sql_ad_admin_login           = "sqladmin-aad"
# sql_ad_admin_object_id       = "<azure-ad-object-id>"
# client_ip_address            = "<your-client-ip-address>"
# query_editor_ip_address      = "<your-query-editor-ip-address>"
